# AnyShare upstream service
ANYSHARE_BASE_URL=https://anyshare.example.com
ANYSHARE_AUTH_COOKIE="Authorization=Bearer ...; JSESSIONID=..."

# Credentials used by WebDAV clients. These are independent from AnyShare.
ANYSHARE_DAV_USERNAME=anyshare-x
ANYSHARE_DAV_PASSWORD=change-this-password

# WebDAV listener
ANYSHARE_DAV_HOST=127.0.0.1
ANYSHARE_DAV_PORT=18765
ANYSHARE_DAV_READONLY=false
ANYSHARE_DAV_CACHE_TTL=5
ANYSHARE_DAV_QUIET=false

# Only enable this for AnyShare deployments with an untrusted/private certificate.
ANYSHARE_DAV_INSECURE=false

# Optional HTTPS listener certificate. Set both or leave both empty.
ANYSHARE_DAV_CERTFILE=
ANYSHARE_DAV_KEYFILE=

# Windows Mount service (used by Mount/ scripts)
ANYSHARE_MOUNT_DRIVE=X:
# Optional public/local URL override. Empty means derive it from DAV host/port.
ANYSHARE_MOUNT_URL=
ANYSHARE_MOUNT_TLS_VERIFY=true
ANYSHARE_MOUNT_WAIT_SECONDS=60
