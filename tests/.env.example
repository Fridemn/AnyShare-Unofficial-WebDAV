# Set to 1 to enable online integration tests against a real AnyShare deployment
TEST_ONLINE=0

# Base URL of the AnyShare deployment used for online tests
TEST_BASE_URL=https://example.com

# Public sharing link (with download and upload permissions) to test the anonymous client
TEST_SHARING_LINK=https://example.com/link/ABCDEF

# Authentication cookie string for testing the authenticated client
TEST_AUTH_COOKIE=your_session_cookie_string_here

# Path to the test directory (that can be accessed via TEST_AUTH_COOKIE) in GNS for testing the authenticated client
TEST_DIR_PATH=gns://your_test_directory_path_here
